reset

set terminal qt enhanced persist

unset key
set title "Original density distribution"

set xlabel "x"
set ylabel "y"
set zlabel "z"

set xrange [0:128]
set yrange [0:128]
set zrange [-16:0]

set view 60, 35
set ticslevel 0

set palette rgb 33,13,10
set colorbox
set cblabel "value"
set cbrange [225:275]

$density << EOD
# x y z value
62 62 -2 250
66 62 -2 250
62 66 -2 250
66 66 -2 250
EOD

splot $density using 1:2:3:4 with points pt 5 ps 1 lc palette
