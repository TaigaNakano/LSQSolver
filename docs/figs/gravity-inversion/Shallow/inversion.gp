reset

set terminal qt enhanced persist
set terminal svg enhanced background "#ffffff"

set output "./inversion.svg" 
set border 4095

unset key
set title "Gravity inversion result"

set xlabel "x [m]"
set ylabel "y [m]"
set zlabel "z [m]"

set xrange [0:128]
set yrange [0:128]
set zrange [-16:0]

set view 75, 45
set ticslevel 0

set palette rgb 33,13,10
set colorbox
set cblabel "Density anomaly [kg/m^3]"
set cbrange [-225.03974021012564:225.03974021012564]
set cbrange [0.0:250]

$density << EOD
